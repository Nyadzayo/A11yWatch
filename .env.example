# Copy to backend/.env (git-ignored). These are placeholders, not secrets.

# --- Database / queue ---
DATABASE_URL=postgresql+asyncpg://a11ywatch:a11ywatch@localhost:5432/a11ywatch
REDIS_URL=redis://localhost:6379/0

# --- Auth (JWT) ---
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=60

# --- Scanning limits (per the robustness requirements) ---
SCAN_PAGE_TIMEOUT_SECONDS=30        # per-page load/run timeout
SCAN_SITE_TIMEOUT_SECONDS=600       # overall per-site scan timeout
SCAN_MAX_PAGES=50                   # crawl cap when no sitemap/url list
SCAN_MAX_RETRIES=2                  # retries after the first attempt (2 -> 3 total), increasing backoff

# --- Worker / scheduler ---
WORKER_CONCURRENCY=2                # start low (2-4); scale by adding workers
SCHEDULER_INTERVAL_SECONDS=60       # how often the scheduler checks for due sites
SCHEDULER_STAGGER_SECONDS=30        # spread enqueues so scans don't all fire at once

# --- Operator self-monitoring ---
HEALTHCHECK_PING_URL=               # e.g. https://hc-ping.com/<uuid> — pinged every scheduler cycle

# --- Alerts ---
OPERATOR_ALERT_EMAIL=               # scan failures go HERE (operator), not customers
SMTP_URL=                          # smtp://user:pass@host:port for customer alerts
