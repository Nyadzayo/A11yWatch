{
  "manifest_version": 3,
  "name": "A11yTrail — Accessibility Checker (WCAG & ADA)",
  "version": "0.1.0",
  "description": "Free WCAG & ADA accessibility checker — scan any page for accessibility issues and get fix guidance.",
  "permissions": ["activeTab", "scripting"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "A11yTrail — Accessibility Checker (WCAG & ADA)",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
