{
  "manifest_version": 3,
  "name": "A11yWatch — Accessibility Checker",
  "version": "0.1.0",
  "description": "Find accessibility issues on the current page — severity, fix guidance, and WCAG references. Runs fully in your browser.",
  "permissions": ["activeTab", "scripting"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "A11yWatch — Accessibility Checker",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
