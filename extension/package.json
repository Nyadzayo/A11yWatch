{
  "name": "a11ytrail-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "copy-axe": "node scripts/copy-axe.mjs",
    "icons": "node scripts/make-icons.mjs",
    "predev": "npm run copy-axe",
    "dev": "vite",
    "prebuild": "npm run copy-axe",
    "build": "vite build",
    "preview": "vite preview",
    "prepackage": "npm run build",
    "package": "rm -f a11ytrail-extension-v$npm_package_version.zip && cd dist && zip -qr ../a11ytrail-extension-v$npm_package_version.zip . && cd .. && echo \"packaged a11ytrail-extension-v$npm_package_version.zip\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "axe-core": "^4.12.1"
  }
}
